# --- Vision Solutions (Next.js client) ---

# Neon / Postgres (Vercel's Neon integration sets DATABASE_URL for you).
# Local dev: paste your Neon connection string (must include ?sslmode=require).
# Example: postgresql://user:pass@ep-xxxx.eu-central-1.aws.neon.tech/vision_solutions?sslmode=require
DATABASE_URL=

# --- Vision AI assistant (chat widget) ---
# Get a key at https://console.anthropic.com/ . Without it, the chat widget shows a
# friendly "not configured" message but the rest of the site works.
ANTHROPIC_API_KEY=
# Optional: override the assistant model
CHAT_MODEL=claude-haiku-4-5-20251001

# --- Admin dashboard (/admin) ---
# Password to view enquiries at /admin. Pick a strong one.
ADMIN_PASSWORD=

# OPTIONAL — only if you run the separate Express server in /server instead.
NEXT_PUBLIC_API_URL=
